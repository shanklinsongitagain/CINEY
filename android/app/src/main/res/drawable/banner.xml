<?xml version="1.0" encoding="utf-8"?>
<!-- Fire TV banner: 320 × 180 dp -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background: deep cinema black -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0A0A0A" />
        </shape>
    </item>

    <!-- Red accent strip on left edge -->
    <item android:right="288dp">
        <shape android:shape="rectangle">
            <solid android:color="#E50914" />
        </shape>
    </item>

    <!-- Subtle red glow in top-left corner -->
    <item android:bottom="90dp" android:right="200dp">
        <shape android:shape="oval">
            <solid android:color="#33E50914" />
        </shape>
    </item>

    <!-- "C" letterform block — large, centered-left -->
    <item android:left="40dp" android:top="44dp" android:right="216dp" android:bottom="44dp">
        <shape android:shape="rectangle">
            <solid android:color="#E50914" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Inner cutout to make a "C" shape -->
    <item android:left="60dp" android:top="64dp" android:right="220dp" android:bottom="64dp">
        <shape android:shape="rectangle">
            <solid android:color="#0A0A0A" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- CINEY label area: three stacked bars (simulate text) -->
    <!-- C -->
    <item android:left="148dp" android:top="58dp" android:right="172dp" android:bottom="118dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <!-- I -->
    <item android:left="178dp" android:top="58dp" android:right="186dp" android:bottom="118dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <!-- N -->
    <item android:left="192dp" android:top="58dp" android:right="216dp" android:bottom="118dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <!-- E -->
    <item android:left="222dp" android:top="58dp" android:right="246dp" android:bottom="118dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <!-- Y -->
    <item android:left="252dp" android:top="58dp" android:right="276dp" android:bottom="118dp">
        <shape android:shape="rectangle">
            <solid android:color="#E50914" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- Bottom tagline bar -->
    <item android:left="148dp" android:top="128dp" android:right="290dp" android:bottom="136dp">
        <shape android:shape="rectangle">
            <solid android:color="#333333" />
            <corners android:radius="2dp" />
        </shape>
    </item>

</layer-list>
